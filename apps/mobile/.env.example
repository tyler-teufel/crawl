EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1
# For physical device use your machine's LAN IP: http://192.168.x.x:3000/api/v1
# For Railway staging: https://<your-railway-url>/api/v1

# Supabase client (safe to ship to the app — publishable key is public)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=sb_publishable_...

# Google Sign-In (https://console.cloud.google.com → APIs & Services → Credentials)
# Create OAuth 2.0 client IDs of type "iOS" and "Web application".
# The Web client ID is required by GoogleSignin on both iOS and Android — it is
# the audience for the id_token Supabase verifies.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
# Also set the reversed iOS client ID in apps/mobile/app.json under the
# @react-native-google-signin/google-signin plugin (iosUrlScheme).
