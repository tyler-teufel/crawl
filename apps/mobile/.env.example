# ─── API ──────────────────────────────────────────────────────────────────────
# Local dev:       http://localhost:3000/api/v1
# Physical device: http://192.168.x.x:3000/api/v1  (use your machine's LAN IP)
# Android emulator reaching host: http://10.0.2.2:3000/api/v1
# Railway staging: https://<your-railway-app>.up.railway.app/api/v1
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Used for: venue reads, city list, authentication sessions.
# The publishable key is safe to ship — it is not a secret.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=sb_publishable_...

# ─── Google Sign-In ───────────────────────────────────────────────────────────
# Create OAuth 2.0 client IDs at https://console.cloud.google.com →
# APIs & Services → Credentials. You need one of type "iOS" and one of type
# "Web application". The Web client ID is required on both iOS and Android —
# it is the audience for the id_token that Supabase verifies.
# Also set the reversed iOS client ID in app.json under the
# @react-native-google-signin/google-signin plugin (iosUrlScheme).
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# ─── Sentry ───────────────────────────────────────────────────────────────────
# DSN is bundled into the shipped app (semi-public). Use a different DSN per
# environment (dev/staging/prod) so events don't mingle across tiers.
# Generate at https://sentry.io → Settings → Projects → <project> → Client Keys.
EXPO_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Build-time only — NOT shipped to the device. Required by the Expo config
# plugin to upload source maps and iOS debug symbols during EAS builds.
# Store this via `eas secret:create --name SENTRY_AUTH_TOKEN --value <token>`,
# not in .env (it is listed here for local reference only).
SENTRY_AUTH_TOKEN=sntrys_...
