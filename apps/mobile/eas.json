{
  "cli": {
    "version": ">= 3.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "simulator": {
      "extends": "development",
      "ios": {
        "simulator": true
      }
    },
    "staging": {
      "environment": "staging",
      "channel": "staging",
      "android": {
        "distribution": "internal"
      },
      "ios": {
        "distribution": "store",
        "simulator": false
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production"
    }
  },
  "submit": {
    "staging": {
      "ios": {}
    },
    "production": {
      "ios": {},
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json"
      }
    }
  }
}
