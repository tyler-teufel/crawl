{
  "cli": {
    "version": ">= 3.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "simulator": {
      "extends": "development",
      "ios": {
        "simulator": true
      }
    },
    "staging": {
      "channel": "staging",
      "android": {
        "distribution": "internal"
      },
      "ios": {
        "distribution": "app-store",
        "simulator": false
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production"
    }
  },
  "submit": {
    "staging": {
      "ios": {
        "appleId": "tdteufel@gmail.com",
        "ascAppId": "YOUR_ASC_APP_ID"
      }
    },
    "production": {
      "ios": {
        "appleId": "tdteufel@gmail.com",
        "ascAppId": "YOUR_ASC_APP_ID"
      },
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json"
      }
    }
  }
}
