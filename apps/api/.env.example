# Supabase Dashboard → Project Settings → Data API → Project URL
# The API derives the JWKS endpoint (auth/v1/.well-known/jwks.json) from this.
SUPABASE_URL=https://your-project-ref.supabase.co

# Optional: only set for projects that have not migrated to asymmetric JWT
# signing keys yet. Found under Project Settings → JWT Keys → "Legacy JWT Secret".
# Leave unset once the project has been migrated via "Migrate JWT secret".
SUPABASE_JWT_SECRET=

# App runtime: Transaction pooler (port 6543) — Dashboard → Settings → Database → Connection string → Transaction
DATABASE_URL=postgresql://postgres.your-ref:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# drizzle-kit only (generate/migrate/push/pull): direct connection (port 5432) — Dashboard → Settings → Database → Connection string → Direct
# The pooler's Transaction mode can break DDL/migrations. Not used by the app itself.
DIRECT_URL=postgresql://postgres:password@db.your-ref.supabase.co:5432/postgres

# Set to true when pointing at real Supabase DB
USE_REAL_DB=false

# Server
PORT=3000
NODE_ENV=development
JWT_SECRET=local-dev-secret-min-32-chars-long
JWT_REFRESH_SECRET=local-dev-refresh-secret-min-32-chars-long
