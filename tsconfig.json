{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    // NativeWind v4 requires react-jsx transform with its jsxImportSource.
    // This aligns tsconfig with the babel-preset-expo jsxImportSource option.
    "jsx": "react-jsx",
    "jsxImportSource": "nativewind"
  }
}
